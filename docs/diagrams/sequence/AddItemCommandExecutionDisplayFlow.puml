@startuml
title Sequence Diagram for AddItemCommand (Execution and Result Display)

autonumber
hide footbox

actor User
participant ":InventoryDock" as InventoryDock
participant ":AddItemCommand" as AddItemCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":UI" as UI

InventoryDock -> AddItemCommand: execute(inventory, ui)
activate AddItemCommand
AddItemCommand -> Inventory: findCategoryByName(categoryName)
activate Inventory
loop for each category in inventory
    Inventory -> Category: getName()
    activate Category
    Category --> Inventory: name
    deactivate Category
end
Inventory --> AddItemCommand: matchingCategory
deactivate Inventory

AddItemCommand -> Category: addItem(item)
activate Category
Category --> AddItemCommand
deactivate Category

AddItemCommand -> UI: showItemAdded(...)
activate UI
UI --> User: display confirmation
deactivate UI
@enduml
