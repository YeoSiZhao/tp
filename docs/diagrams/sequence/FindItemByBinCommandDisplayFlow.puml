@startuml
title Sequence Diagram for FindItemByBinCommand (Result Display)

autonumber
hide footbox

actor User
participant ":FindItemByBinCommand" as FindItemByBinCommand
participant ":UI" as UI

activate FindItemByBinCommand
alt matches is empty
    FindItemByBinCommand -> UI: showMessage("No items found ...")
    activate UI
    UI --> FindItemByBinCommand: no-match message displayed
    deactivate UI
    FindItemByBinCommand --> User: no-match message shown
else matches found
    FindItemByBinCommand -> UI: showDivider()
    activate UI
    FindItemByBinCommand -> UI: showMessage("Items in bin location ...")
    FindItemByBinCommand -> UI: showNumberedList(matches)
    FindItemByBinCommand -> UI: showDivider()
    UI --> FindItemByBinCommand: matching items displayed
    deactivate UI
    FindItemByBinCommand --> User: matching items shown
end
deactivate FindItemByBinCommand
@enduml

